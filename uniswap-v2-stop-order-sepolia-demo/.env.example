# Copy to .env and source it before running deployment commands:
#   cp .env.example .env
#   source .env

# Required RPCs and keys
DESTINATION_RPC=
DESTINATION_PRIVATE_KEY=
REACTIVE_RPC=
REACTIVE_PRIVATE_KEY=

# Reactive callback verification address on Sepolia destination
DESTINATION_CALLBACK_PROXY_ADDR=

# Your EOA address
CLIENT_WALLET=

# This demo runs against Ethereum Sepolia for the destination side.
# ORIGIN_* variables from the top-level repo are not needed here.

# Optional preset test tokens from the demo README
TK1=0x2AFDE4A3Bca17E830c476c568014E595EA916a04
TK2=0x7EB2Ad352369bb6EDEb84D110657f2e40c912c95
UNISWAP_V2_PAIR_ADDR=0x1DD11fD3690979f2602E42e7bBF68A19040E2e25

# Uniswap V2 Sepolia infra used by this demo
UNISWAP_V2_FACTORY_ADDR=0x7E0987E5b3a30e3f2828572Bb659A548460a3003
UNISWAP_V2_ROUTER_ADDR=0xC532a74256D3Db42D0Bf7a0400fEFDbad7694008

# Fill these after deployment or if you create your own pair/tokens
TOKEN0_ADDR=
TOKEN1_ADDR=
TOKEN_ADDR=
CALLBACK_ADDR=

# Stop-order parameters for the Reactive contract deployment
DIRECTION_BOOLEAN=true
EXCHANGE_RATE_DENOMINATOR=1000
EXCHANGE_RATE_NUMERATOR=1234

# Common demo amounts with 18 decimals
LIQUIDITY_TOKEN0_AMOUNT=10000000000000000000
LIQUIDITY_TOKEN1_AMOUNT=10000000000000000000
APPROVE_AMOUNT=1000000000000000000
TRIGGER_TRANSFER_AMOUNT=20000000000000000
TRIGGER_SWAP_AMOUNT_OUT=5000000000000000
