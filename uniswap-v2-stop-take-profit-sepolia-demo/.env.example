# Copy to .env before running the helper script:
#   cp .env.example .env

# RPCs and private keys
DESTINATION_RPC=
DESTINATION_PRIVATE_KEY=
REACTIVE_RPC=https://lasna-rpc.rnk.dev/
REACTIVE_PRIVATE_KEY=

# Sepolia callback proxy
DESTINATION_CALLBACK_PROXY_ADDR=0xc9f36411C9897e7F959D99ffca2a0Ba7ee0D7bDA

# Wallet that owns the callback contract and the orders
USER_WALLET=

# Optional alias used by older scripts
CLIENT_WALLET=

# Default Uniswap V2 Sepolia infrastructure
UNISWAP_V2_FACTORY_ADDR=0x7E0987E5b3a30e3f2828572Bb659A548460a3003
UNISWAP_V2_ROUTER_ADDR=0xC532a74256D3Db42D0Bf7a0400fEFDbad7694008

# Optional preset demo tokens / pair from the official README
TK1=0x2AFDE4A3Bca17E830c476c568014E595EA916a04
TK2=0x7EB2Ad352369bb6EDEb84D110657f2e40c912c95
UNISWAP_V2_PAIR_ADDR=0x1DD11fD3690979f2602E42e7bBF68A19040E2e25

# Fill these after deployment if you create your own setup
TOKEN0_ADDR=
TOKEN1_ADDR=
CALLBACK_ADDR=

# Order settings
ORDER_SELL_TOKEN0=true
ORDER_AMOUNT_WEI=1000000000000000000
ORDER_COEFFICIENT=10000
ORDER_THRESHOLD=12000
ORDER_TYPE=1

# Liquidity and trigger settings
LIQUIDITY_TOKEN0_AMOUNT=10000000000000000000
LIQUIDITY_TOKEN1_AMOUNT=10000000000000000000
APPROVE_AMOUNT=1000000000000000000
CALLBACK_PROXY_DEPOSIT=0.01ether
TRIGGER_TRANSFER_AMOUNT=20000000000000000
TRIGGER_SWAP_AMOUNT0_OUT=0
TRIGGER_SWAP_AMOUNT1_OUT=5000000000000000
